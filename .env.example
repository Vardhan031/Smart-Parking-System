# Copy this file to .env and fill in the required values before running docker compose.

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret

# ── Optional: Firebase push notifications ─────────────────────────────────────
# Provide either the JSON string or the path to the key file (not both).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase_key.json

# ── Optional: Frontend API URL ────────────────────────────────────────────────
# This URL is baked into the frontend bundle at build time.
# Change it if you are deploying to a remote server.
# VITE_API_BASE_URL=http://localhost:5000/api

# ── Optional: ANPR Service ────────────────────────────────────────────────────
# ANPR_MODEL_PATH=models/best.pt
# ANPR_USE_GPU=false
